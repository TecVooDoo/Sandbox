    totalAttenColor = 0@$\tuint lightCount = GetAdditionalLightsCount()@$\tfor (uint
    lightIndex = 0u@ lightIndex < lightCount@ ++lightIndex)$\t{$\t\t#if ASE_SRP_VERSION
